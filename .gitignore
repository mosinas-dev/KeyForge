# === KeyForge .gitignore ===
# Container-first: entry scripts, *-local.php and composer.lock ARE committed so
# the image/CI run with no `yii init`. Only regenerated/secret artifacts are ignored.

# --- OS / IDE ---
.DS_Store
.idea/
.vscode/
nbproject/
*.swp
Thumbs.db

# --- Secrets / local env (consumed by docker-compose) ---
.env

# --- Composer (composer.lock is intentionally committed) ---
/vendor/
composer.phar

# --- Yii2 runtime logs + compiled web assets (regenerated; dirs kept via .gitkeep) ---
**/runtime/*
!**/runtime/.gitkeep
**/web/assets/*
!**/web/assets/.gitkeep

# --- Codeception generated output + actor internals (regenerated by `codecept build`) ---
**/tests/_output/*
!**/tests/_output/.gitkeep
**/tests/Support/_generated/
**/tests/Support/output/
console/runtime/output/

# --- Node (not used yet) ---
/node_modules/
/package-lock.json

# --- Codeception c3 coverage temp ---
/c3tmp/
