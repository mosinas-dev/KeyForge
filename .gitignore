# --- OS / IDE ---
.DS_Store
.idea/
nbproject/
.vscode/
*.swp

# --- Secrets / local env (consumed by docker-compose) ---
.env

# --- Composer ---
/vendor/
composer.phar
# composer.lock IS committed (reproducible builds) — do not ignore it.

# --- Yii2 advanced: runtime, built assets, local configs ---
# (per-app .gitignore files arrive with `composer create-project` in Phase 0;
#  these root-level entries are a safety net so generated artifacts never leak in.)
**/runtime/
**/web/assets/
**/web/index-test.php
/console/runtime/
/backend/web/assets/
/frontend/web/assets/
config/*-local.php
**/config/*-local.php

# --- Test / coverage artifacts ---
/tests/_output/
/tests/_support/_generated/
*.phar

# --- Docker / build ---
# (Dockerfile, docker-compose.yml, docker/ ARE committed — only build junk is ignored.)
